# API base URL used by the browser. Must be reachable from the client.
# Docker: use http://localhost:8080 (API is mapped to host port 8080).
# Local dev: use http://localhost:8080 (API runs on 8080).
NUXT_PUBLIC_API_BASE=http://localhost:8080

# Server-side only (SSR). In Docker set to http://api:8080 so the frontend container can reach the API.
# Optional when not using Docker.
# NUXT_API_BASE=http://api:8080
