# Copy to .env and fill in values. Do not commit .env.
# docker compose up works without .env (uses default POSTGRES_PASSWORD and other defaults).

# Postgres (used by api and audit-consumer; optional - defaults applied if unset)
POSTGRES_PASSWORD=change_me
# POSTGRES_USER=securevault
# POSTGRES_DB=securevault

# Required for API encryption (generate 32-byte key):
#   PowerShell: [Convert]::ToBase64String((1..32|%{[byte](Get-Random -Max 256)}))
#   Bash:       openssl rand -base64 32
Encryption__MasterKeyBase64=

# Optional overrides for docker-compose
# SECUREVAULT_BASE_URL=http://localhost:3000
# CORS_ORIGINS=http://localhost:3000
# NUXT_PUBLIC_API_BASE=http://localhost:8080
# PGADMIN_DEFAULT_EMAIL=admin@example.com
# PGADMIN_DEFAULT_PASSWORD=admin123
